{% comment %}
  CPU Stress Test Simulator - eko branded
  Settings controlled via URL parameters for easy sharing/benchmarking
  
  URL Parameters:
  - stress=1           : Auto-start stress test on page load
  - intensity=off|low|medium|high|extreme
  - duration=5|10|15|30|60|0 (0=infinite)
  - js=1|0             : Enable JS compute stress
  - layout=1|0         : Enable layout thrashing
  - longtasks=1|0      : Enable long blocking tasks
  - memory=1|0         : Enable memory pressure (GC stress)
  - dom=1|0            : Enable DOM render tree stress
  - network=1|0        : Enable network/event loop stress
  
  Example: ?stress=1&intensity=high&duration=30&js=1&layout=1&longtasks=1&memory=1&dom=1&network=1
{% endcomment %}

<!-- IMMEDIATE EXECUTION: Run stress test BEFORE page renders if URL params set -->
<script>
(function() {
  'use strict';
  
  // Parse URL parameters
  const urlParams = new URLSearchParams(window.location.search);
  const stressActive = urlParams.get('stress') === '1';
  
  console.log('%c[eko Stress] URL Check', 'color: #8b5cf6; font-weight: bold;', {
    fullURL: window.location.href,
    search: window.location.search,
    stressParam: urlParams.get('stress'),
    stressActive: stressActive
  });
  
  if (stressActive) {
    const intensity = urlParams.get('intensity') || 'medium';
    const duration = parseInt(urlParams.get('duration') || '30', 10);
    const config = {
      js: urlParams.get('js') !== '0',
      layout: urlParams.get('layout') !== '0',
      longtasks: urlParams.get('longtasks') !== '0',
      memory: urlParams.get('memory') === '1',
      dom: urlParams.get('dom') === '1',
      network: urlParams.get('network') === '1'
    };
    
    // Intensity settings calibrated for target blocking percentages:
    // Low: ~45%, Medium: ~65%, High: ~82%, Extreme: ~99%
    const intensitySettings = {
      off: { iterations: 0, blockMs: 0, layoutOps: 0, memoryAllocs: 0, domOps: 0, networkOps: 0 },
      low: { iterations: 8000, blockMs: 15, layoutOps: 8, memoryAllocs: 3, domOps: 2, networkOps: 2 },
      medium: { iterations: 80000, blockMs: 80, layoutOps: 40, memoryAllocs: 15, domOps: 8, networkOps: 8 },
      high: { iterations: 400000, blockMs: 250, layoutOps: 125, memoryAllocs: 45, domOps: 25, networkOps: 25 },
      extreme: { iterations: 2000000, blockMs: 800, layoutOps: 500, memoryAllocs: 150, domOps: 100, networkOps: 100 }
    };

    const cfg = intensitySettings[intensity] || intensitySettings.medium;
    
    // If intensity is "off", don't run any stress test at all
    if (intensity === 'off') {
      console.log('%c⚪ eko Stress Test: OFF (no load)', 'background: #71717a; color: white; padding: 8px 16px; font-weight: bold; border-radius: 4px;');
      console.log('Page will load normally with no artificial delays.');
      return;
    }
    
    console.log('%c⚡ eko Stress Test ACTIVE', 'background: linear-gradient(90deg, #6366f1, #8b5cf6); color: white; padding: 8px 16px; font-weight: bold; border-radius: 4px;');
    console.log('%cSettings:', 'color: #a78bfa;', { intensity, duration, config, cfg });
    
    const startTime = performance.now();
    const endTime = duration > 0 ? startTime + (duration * 1000) : Infinity;
    
    console.log('%c[eko Stress] Timing:', 'color: #8b5cf6;', {
      startTime: startTime,
      endTime: endTime,
      durationMs: duration * 1000,
      willRunFor: duration > 0 ? duration + ' seconds' : 'infinite'
    });
    
    // Graph data
    const graphData = [];
    const maxGraphPoints = 60;
    
    // Store for panel reference
    window.__stressState = {
      active: true,
      startTime: startTime,
      endTime: endTime,
      intensity: intensity,
      duration: duration,
      config: config,
      totalOps: 0,
      blockedTime: 0,
      elapsedMs: 0,
      graphData: graphData
    };
    
    // Add performance mark
    performance.mark('eko-stress-start');

    // IMMEDIATE synchronous blocking during page load (this is the key!)
    console.log('%c[eko Stress] About to start initial block...', 'color: #f97316;', {
      longtasksEnabled: config.longtasks,
      jsEnabled: config.js,
      layoutEnabled: config.layout,
      blockMs: cfg.blockMs,
      iterations: cfg.iterations
    });
    
    if (config.longtasks) {
      const syncBlockStart = performance.now();
      const syncBlockDuration = cfg.blockMs * 3;
      console.log('%c[eko Stress] Starting sync block for ' + syncBlockDuration + 'ms', 'color: #f97316;');
      
      const heavyWork = [];
      while (performance.now() - syncBlockStart < syncBlockDuration) {
        let x = Math.sqrt(Math.random() * 1000000);
        x = Math.sin(x) * Math.cos(x) * Math.tan(x);
        
        const str = 'stress'.repeat(100) + Math.random().toString(36);
        const hash = str.split('').reduce((a, c) => a + c.charCodeAt(0), 0);
        
        heavyWork.push({ x, hash, arr: new Array(100).fill(x) });
        if (heavyWork.length > 1000) heavyWork.length = 0;
        
        window.__stressState.totalOps++;
      }
      
      const initialBlock = performance.now() - syncBlockStart;
      window.__stressState.blockedTime += initialBlock;
      graphData.push(initialBlock);
      console.log(`%c🔥 Initial page-load block: ${Math.round(initialBlock)}ms`, 'color: #f97316; font-weight: bold;');
      console.log('%c[eko Stress] Initial block complete, state:', 'color: #f97316;', {
        blockedTime: window.__stressState.blockedTime,
        totalOps: window.__stressState.totalOps,
        active: window.__stressState.active
      });
    } else {
      console.log('%c[eko Stress] Skipping initial block (longtasks disabled)', 'color: #71717a;');
    }

    // Counter for periodic logging
    let logCounter = 0;
    let frameCount = 0;

    console.log('%c[eko Stress] Defining blockMainThread, will start loop...', 'color: #6366f1;');
    
    function blockMainThread() {
      frameCount++;
      
      // Debug: Log state check on first few frames
      if (frameCount <= 5) {
        console.log('%c[eko Stress] Frame ' + frameCount + ' check:', 'color: #8b5cf6;', {
          active: window.__stressState.active,
          currentTime: performance.now(),
          endTime: window.__stressState.endTime,
          timeRemaining: window.__stressState.endTime - performance.now()
        });
      }
      
      if (!window.__stressState.active) {
        console.log('%c✅ eko Stress Test completed', 'background: #10b981; color: white; padding: 4px 8px; border-radius: 4px;');
        console.log(`   Total blocked time: ${Math.round(window.__stressState.blockedTime)}ms`);
        console.log(`   Total operations: ${window.__stressState.totalOps.toLocaleString()}`);
        performance.mark('eko-stress-end');
        performance.measure('eko-stress-duration', 'eko-stress-start', 'eko-stress-end');
        return;
      }
      
      if (performance.now() > window.__stressState.endTime) {
        console.log('%c[eko Stress] Time expired, ending test', 'color: #f59e0b;');
        window.__stressState.active = false;
        blockMainThread();
        return;
      }
      
      const blockStart = performance.now();
      let result = 0;
      const heavyWork = [];
      
      // JS Compute stress
      if (config.js) {
        for (let i = 0; i < cfg.iterations; i++) {
          result += Math.sqrt(Math.random() * 1000000);
          result = Math.sin(result) * Math.cos(result);
          result = Math.tan(Math.atan(result));
          
          if (i % 10000 === 0) {
            const str = 'block'.repeat(50) + result.toString(36);
            heavyWork.push({ i, str: str.slice(0, 100), arr: [result, result * 2] });
            if (heavyWork.length > 100) heavyWork.length = 0;
          }
          
          window.__stressState.totalOps++;
        }
      }
      
      // Layout thrashing
      if (config.layout && document.body) {
        for (let i = 0; i < cfg.layoutOps; i++) {
          const _ = document.body.offsetHeight;
          document.body.style.paddingBottom = (i % 2) + 'px';
          const __ = document.body.offsetWidth;
          document.body.style.paddingBottom = '';
          
          if (i % 20 === 0) {
            const elements = document.querySelectorAll('div, span, img');
            let count = 0;
            elements.forEach(el => {
              if (count++ < 50) {
                el.getBoundingClientRect();
              }
            });
          }
        }
      }
      
      // Additional synchronous blocking
      if (config.longtasks) {
        const extraBlockTime = cfg.blockMs / 4;
        const extraStart = performance.now();
        while (performance.now() - extraStart < extraBlockTime) {
          Math.random() * Math.random();
          window.__stressState.totalOps++;
        }
      }
      
      // Memory pressure stress - allocates and manipulates memory, triggers GC
      if (config.memory) {
        const memoryChunks = [];
        for (let i = 0; i < cfg.memoryAllocs; i++) {
          // Allocate typed arrays (more realistic than plain objects)
          const chunk = new Float64Array(10000);
          for (let j = 0; j < chunk.length; j++) {
            chunk[j] = Math.random() * i;
          }
          memoryChunks.push(chunk);
          
          // Periodically release to trigger GC
          if (memoryChunks.length > 50) {
            memoryChunks.splice(0, 25);
          }
          window.__stressState.totalOps++;
        }
      }
      
      // DOM render tree stress - heavy DOM node creation/removal
      if (config.dom && document.body) {
        const container = document.createElement('div');
        container.style.cssText = 'position:absolute;opacity:0;pointer-events:none;left:-9999px;';
        document.body.appendChild(container);
        
        for (let i = 0; i < cfg.domOps; i++) {
          // Create deep nested structure
          const fragment = document.createDocumentFragment();
          let parent = fragment;
          for (let d = 0; d < 10; d++) {
            const child = document.createElement('div');
            child.className = 'stress-node-' + d;
            child.textContent = 'Node ' + i + '-' + d;
            parent.appendChild(child);
            parent = child;
          }
          container.appendChild(fragment);
          
          // Clear periodically
          if (container.childNodes.length > 100) {
            container.innerHTML = '';
          }
          window.__stressState.totalOps++;
        }
        container.remove();
      }
      
      // Network/event loop stress - simulates heavy async I/O
      if (config.network) {
        for (let i = 0; i < cfg.networkOps; i++) {
          // Create data URIs to fetch (no actual network, but stresses fetch API and event loop)
          const blob = new Blob([JSON.stringify({ stress: i, data: 'x'.repeat(1000) })]);
          const url = URL.createObjectURL(blob);
          
          // Fire-and-forget fetches to saturate the task queue
          fetch(url)
            .then(r => r.json())
            .then(() => {
              URL.revokeObjectURL(url);
              window.__stressState.totalOps++;
            })
            .catch(() => URL.revokeObjectURL(url));
        }
        window.__stressState.totalOps += cfg.networkOps;
      }
      
      const blockDuration = performance.now() - blockStart;
      window.__stressState.blockedTime += blockDuration;
      window.__stressState.elapsedMs = performance.now() - window.__stressState.startTime;
      window.__stressResult = result;
      
      // Update graph data
      graphData.push(blockDuration);
      if (graphData.length > maxGraphPoints) graphData.shift();
      
      // Periodic logging (every ~1 second)
      logCounter++;
      if (frameCount <= 3 || logCounter % 250 === 0) {
        console.log(`%c⚡ Frame ${frameCount}: blocked ${Math.round(blockDuration)}ms, total ${Math.round(window.__stressState.blockedTime)}ms, ops ${window.__stressState.totalOps}`, 'color: #6366f1;');
      }
      
      setTimeout(blockMainThread, 4);
    }
    
    console.log('%c[eko Stress] Starting first call to blockMainThread...', 'color: #10b981; font-weight: bold;');
    blockMainThread();
    console.log('%c[eko Stress] First blockMainThread call returned (async loop scheduled)', 'color: #10b981;');
  }
})();
</script>

<!-- eko Branded Floating Control Panel -->
