        <label class="eko-toggle-inline checked" id="toggle-longtasks-wrap">
          <input type="checkbox" id="toggle-longtasks" checked onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">Long Tasks</span>
