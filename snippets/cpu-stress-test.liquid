<script>
(function() {
  'use strict';

  window.EkoStress = {
    settings: {
      intensity: 'medium',
      duration: 30,
      js: true,
      layout: true,
      longtasks: true,
      memory: false,
      dom: false,
      network: false
    },
    
    previousToggleState: {
      js: true,
      layout: true,
      longtasks: true,
      memory: false,
      dom: false,
      network: false
    },

    init() {
      console.log('%c[eko Panel] Initializing...', 'color: #6366f1; font-weight: bold;');
      
      try {
        this.loadFromStorage();
        console.log('[eko Panel] ✓ loadFromStorage');
      } catch (e) { console.error('[eko Panel] loadFromStorage failed:', e); }
      
      try {
        this.loadFromURL();
        console.log('[eko Panel] ✓ loadFromURL');
      } catch (e) { console.error('[eko Panel] loadFromURL failed:', e); }
      
      try {
        this.updateUI();
        console.log('[eko Panel] ✓ updateUI');
      } catch (e) { console.error('[eko Panel] updateUI failed:', e); }
      
      try {
        this.updateURL();
      } catch (e) { console.error('[eko Panel] updateURL failed:', e); }
      
      try {
        this.checkActiveTest();
        console.log('[eko Panel] ✓ checkActiveTest');
      } catch (e) { console.error('[eko Panel] checkActiveTest failed:', e); }
      
      try {
        this.makeDraggable();
        console.log('[eko Panel] ✓ makeDraggable');
      } catch (e) { console.error('[eko Panel] makeDraggable failed:', e); }
      
      try {
        this.initGraph();
        console.log('[eko Panel] ✓ initGraph');
      } catch (e) { console.error('[eko Panel] initGraph failed:', e); }
      
      console.log('%c[eko Panel] Checking stress state:', 'color: #6366f1;', {
        stressStateExists: !!window.__stressState,
        active: window.__stressState?.active,
        settings: this.settings
      });
      
      if (window.__stressState && window.__stressState.active) {
        console.log('%c[eko Panel] Starting metrics update!', 'color: #10b981; font-weight: bold;');
        this.startMetricsUpdate();
      } else {
        console.log('%c[eko Panel] No active stress test detected', 'color: #f59e0b;');
      }
    },
    
    initGraph() {
      // Impact meter is initialized via HTML, nothing to do here
    },

    loadFromStorage() {
      try {
        const saved = localStorage.getItem('ekoStressSettings');
        if (saved) {
          const parsed = JSON.parse(saved);
          // Merge saved settings with defaults
          Object.assign(this.settings, parsed);
          console.log('[eko Panel] Loaded settings from localStorage:', this.settings);
        }
      } catch (e) {
        console.warn('[eko Panel] Could not load settings from localStorage:', e);
      }
    },
    
    saveToStorage() {
      try {
        localStorage.setItem('ekoStressSettings', JSON.stringify(this.settings));
        console.log('[eko Panel] Saved settings to localStorage');
      } catch (e) {
        console.warn('[eko Panel] Could not save settings to localStorage:', e);
      }
    },

    loadFromURL() {
      const params = new URLSearchParams(window.location.search);
      
      // Only override from URL if params are explicitly set
      if (params.has('intensity')) {
        this.settings.intensity = params.get('intensity');
      }
      if (params.has('duration')) {
        this.settings.duration = parseInt(params.get('duration'), 10);
      }
      if (params.has('js')) {
        this.settings.js = params.get('js') !== '0';
      }
      if (params.has('layout')) {
        this.settings.layout = params.get('layout') !== '0';
      }
      if (params.has('longtasks')) {
        this.settings.longtasks = params.get('longtasks') !== '0';
      }
      if (params.has('memory')) {
        this.settings.memory = params.get('memory') === '1';
      }
      if (params.has('dom')) {
        this.settings.dom = params.get('dom') === '1';
      }
      if (params.has('network')) {
        this.settings.network = params.get('network') === '1';
      }
    },

    updateUI() {
      // Intensity buttons
      document.querySelectorAll('.eko-btn[data-level]').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.level === this.settings.intensity);
      });
      
      // Duration buttons
      document.querySelectorAll('.eko-btn[data-duration]').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.duration) === this.settings.duration);
      });
      
      // Toggles
      ['js', 'layout', 'longtasks', 'memory', 'dom', 'network'].forEach(type => {
        const checkbox = document.getElementById(`toggle-${type}`);
        const wrap = document.getElementById(`toggle-${type}-wrap`);
        if (checkbox && wrap) {
          checkbox.checked = this.settings[type];
          wrap.classList.toggle('checked', this.settings[type]);
        }
      });
      
      this.updateToggleState();
    },

    updateToggle(checkbox) {
      const type = checkbox.id.replace('toggle-', '');
      this.settings[type] = checkbox.checked;
      checkbox.closest('.eko-toggle-inline').classList.toggle('checked', checkbox.checked);
      this.updateURL();
      this.saveToStorage();
    },

    updateToggleState() {
      const isOff = this.settings.intensity === 'off';
      const toggles = document.querySelectorAll('.eko-toggle-inline');
      const allTypes = ['js', 'layout', 'longtasks', 'memory', 'dom', 'network'];
      
      if (isOff) {
        // Save current state and turn all off
        if (allTypes.some(type => this.settings[type])) {
          this.previousToggleState = {};
          allTypes.forEach(type => {
            this.previousToggleState[type] = this.settings[type];
          });
        }
        
        allTypes.forEach(type => {
          this.settings[type] = false;
          const checkbox = document.getElementById(`toggle-${type}`);
          const wrap = document.getElementById(`toggle-${type}-wrap`);
          if (checkbox && wrap) {
            checkbox.checked = false;
            wrap.classList.remove('checked');
          }
        });
      }
      
      // Update visual state
      toggles.forEach(toggle => {
        toggle.classList.toggle('disabled', isOff);
      });
      
      // Update status text
      const statusText = document.getElementById('status-text');
      if (statusText && !window.__stressState?.active) {
        statusText.textContent = isOff ? 'Ready (Off Mode)' : 'Ready';
      }
      
      this.updateURL();
    },

    updateURL() {
      this.settings.js = document.getElementById('toggle-js')?.checked ?? this.settings.js;
      this.settings.layout = document.getElementById('toggle-layout')?.checked ?? this.settings.layout;
      this.settings.longtasks = document.getElementById('toggle-longtasks')?.checked ?? this.settings.longtasks;
      this.settings.memory = document.getElementById('toggle-memory')?.checked ?? this.settings.memory;
      this.settings.dom = document.getElementById('toggle-dom')?.checked ?? this.settings.dom;
      this.settings.network = document.getElementById('toggle-network')?.checked ?? this.settings.network;
      
      const baseURL = window.location.origin + window.location.pathname;
      const params = new URLSearchParams();
      
      // Get preview_theme_id from multiple sources
      const currentParams = new URLSearchParams(window.location.search);
      const existingThemeId = currentParams.get('preview_theme_id');
      const panel = document.getElementById('cpu-stress-panel');
      const dataThemeId = panel?.dataset?.themeId;
      
      // Use existing URL param first, then data attribute from Liquid
      const themeId = existingThemeId || dataThemeId;
      
      console.log('[eko Panel] Theme ID sources:', { existingThemeId, dataThemeId, final: themeId });
      
      if (themeId) {
        params.set('preview_theme_id', themeId);
      }
      
      params.set('stress', '1');
      params.set('intensity', this.settings.intensity);
      params.set('duration', this.settings.duration.toString());
      params.set('js', this.settings.js ? '1' : '0');
      params.set('layout', this.settings.layout ? '1' : '0');
      params.set('longtasks', this.settings.longtasks ? '1' : '0');
      params.set('memory', this.settings.memory ? '1' : '0');
      params.set('dom', this.settings.dom ? '1' : '0');
      params.set('network', this.settings.network ? '1' : '0');
      
      const shareURL = baseURL + '?' + params.toString();
      const urlInput = document.getElementById('share-url');
      if (urlInput) {
        urlInput.value = shareURL;
      }
      
      console.log('%c[eko Panel] URL updated:', 'color: #71717a;', shareURL);
    },

    copyURL() {
      const input = document.getElementById('share-url');
      if (input) {
        input.select();
        document.execCommand('copy');
        
        const btn = document.querySelector('.url-copy-btn');
        if (btn) {
          btn.style.color = 'var(--eko-success)';
          setTimeout(() => { btn.style.color = ''; }, 1000);
        }
      }
    },

    setIntensity(level) {
      const wasOff = this.settings.intensity === 'off';
      this.settings.intensity = level;
      
      document.querySelectorAll('.eko-btn[data-level]').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.level === level);
      });
      
      // Restore toggle state when switching from off
      if (wasOff && level !== 'off') {
        ['js', 'layout', 'longtasks', 'memory', 'dom', 'network'].forEach(type => {
          this.settings[type] = this.previousToggleState[type];
          const checkbox = document.getElementById(`toggle-${type}`);
          const wrap = document.getElementById(`toggle-${type}-wrap`);
          if (checkbox && wrap) {
            checkbox.checked = this.settings[type];
            wrap.classList.toggle('checked', this.settings[type]);
          }
        });
      }
      
      this.updateToggleState();
      this.saveToStorage();
    },

    setDuration(seconds) {
      this.settings.duration = seconds;
      document.querySelectorAll('.eko-btn[data-duration]').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.duration) === seconds);
      });
      this.updateURL();
      this.saveToStorage();
    },

    checkActiveTest() {
      const params = new URLSearchParams(window.location.search);
      const stressParam = params.get('stress');
      const hasStressState = !!window.__stressState;
      const isActive = window.__stressState?.active;
      
      console.log('[eko Panel] checkActiveTest:', { stressParam, hasStressState, isActive });
      
      if (stressParam === '1' && hasStressState && isActive) {
        console.log('[eko Panel] Test is active! Updating UI...');
        
        const panel = document.getElementById('cpu-stress-panel');
        const statusDot = document.getElementById('status-dot');
        const statusText = document.getElementById('status-text');
        const banner = document.getElementById('active-test-banner');
        const startBtn = document.getElementById('start-stress');
        const progressContainer = document.getElementById('progress-container');
        
        console.log('[eko Panel] UI elements found:', {
          panel: !!panel,
          statusDot: !!statusDot,
          statusText: !!statusText,
          banner: !!banner,
          startBtn: !!startBtn,
          progressContainer: !!progressContainer
        });
        
        if (panel) panel.classList.add('running');
        if (statusDot) statusDot.classList.add('running');
        if (statusText) statusText.textContent = this.settings.intensity === 'off' ? 'Running (No Load)' : 'Running';
        if (banner) banner.style.display = 'flex';
        if (startBtn) {
          startBtn.classList.add('running');
          startBtn.textContent = 'Running...';
        }
        
        if (this.settings.duration > 0 && progressContainer) {
          progressContainer.style.display = 'block';
        }
        
        console.log('[eko Panel] UI updated for running state');
      } else {
        console.log('[eko Panel] Test not active, skipping UI update');
      }
    },

    startMetricsUpdate() {
      const maxGraphBars = 30; // Reduced to fit in container
      let updateCount = 0;
      
      console.log('%c[eko Panel] Metrics update started', 'color: #10b981; font-weight: bold;');
      
      const self = this; // Capture reference for interval
      setInterval(() => {
        updateCount++;
        if (window.__stressState) {
          // Log every 10 updates (once per second)
          if (updateCount % 10 === 1) {
            console.log('%c[eko Panel] Metrics update #' + updateCount, 'color: #71717a;', {
              active: window.__stressState.active,
              elapsedMs: window.__stressState.elapsedMs,
              blockedTime: window.__stressState.blockedTime,
              totalOps: window.__stressState.totalOps,
              graphDataLength: window.__stressState.graphData?.length
            });
          }
          const elapsed = window.__stressState.elapsedMs / 1000;
          document.getElementById('elapsed-time').textContent = elapsed.toFixed(1) + 's';
          document.getElementById('thread-blocked').textContent = Math.round(window.__stressState.blockedTime) + 'ms';
          
          const ops = window.__stressState.totalOps;
          document.getElementById('total-ops').textContent = 
            ops > 1000000 ? (ops / 1000000).toFixed(1) + 'M' :
            ops > 1000 ? (ops / 1000).toFixed(1) + 'K' : ops;
          
          // Update progress
          if (window.__stressState.duration > 0) {
            const progress = Math.min((elapsed / window.__stressState.duration) * 100, 100);
            document.getElementById('progress-bar').style.width = progress + '%';
            document.getElementById('progress-text').textContent = Math.round(progress) + '%';
          }
          
          // Update impact meter and stats
          const graphData = window.__stressState.graphData || [];

          if (graphData.length > 0) {
            // Calculate meaningful stats
            const recentData = graphData.slice(-maxGraphBars);
            const avgBlock = recentData.reduce((a, b) => a + b, 0) / recentData.length;
            const estimatedFps = Math.max(1, Math.round(1000 / (avgBlock + 16.67)));
            
            // Block rate: what percentage of elapsed time was spent blocking
            const blockRate = Math.min(100, (window.__stressState.blockedTime / window.__stressState.elapsedMs) * 100);
            
            // Impact percentage (0-100): combines block rate with intensity
            // Higher blocking = more impact shown on the meter
            const impactPct = Math.min(100, blockRate);
            
            // Update impact meter - move the tick mark
            const impactTick = document.getElementById('impact-tick');
            const tickValue = document.getElementById('tick-value');
            if (impactTick) {
              impactTick.style.left = impactPct + '%';
            }
            if (tickValue) {
              tickValue.textContent = Math.round(impactPct) + '%';
            }
            
            // Update header display - show impact level text
            const currentValueEl = document.getElementById('graph-current-value');
            if (currentValueEl) {
              let impactText = 'Low';
              let impactColor = 'var(--eko-success)';
              if (impactPct > 75) {
                impactText = 'Severe';
                impactColor = 'var(--eko-danger)';
              } else if (impactPct > 50) {
                impactText = 'High';
                impactColor = 'var(--eko-warning)';
              } else if (impactPct > 25) {
                impactText = 'Medium';
                impactColor = '#f59e0b';
              }
              currentValueEl.textContent = impactText;
              currentValueEl.style.color = impactColor;
            }
            
            const avgEl = document.getElementById('graph-avg');
            if (avgEl) avgEl.textContent = Math.round(avgBlock) + 'ms';
            
            const fpsEl = document.getElementById('graph-fps');
            if (fpsEl) {
              fpsEl.textContent = estimatedFps + 'fps';
              if (estimatedFps < 15) {
                fpsEl.style.color = 'var(--eko-danger)';
              } else if (estimatedFps < 30) {
                fpsEl.style.color = 'var(--eko-warning)';
              } else {
                fpsEl.style.color = 'var(--eko-success)';
              }
            }
            
            const blockRateEl = document.getElementById('graph-block-rate');
            if (blockRateEl) {
              blockRateEl.textContent = Math.round(blockRate) + '%';
              if (blockRate > 75) {
                blockRateEl.style.color = 'var(--eko-danger)';
              } else if (blockRate > 50) {
                blockRateEl.style.color = 'var(--eko-warning)';
              } else {
                blockRateEl.style.color = 'var(--eko-text)';
              }
            }
          }
          
          if (!window.__stressState.active) {
            self.onTestEnded();
          }
        } else {
          console.warn('[eko Panel] window.__stressState is undefined!');
        }
      }, 100);
    },

    onTestEnded() {
      document.getElementById('cpu-stress-panel').classList.remove('running');
      document.getElementById('status-dot').classList.remove('running');
      document.getElementById('status-text').textContent = 'Completed';
      document.getElementById('active-test-banner').style.display = 'none';
      
      // Change button to "Complete" with success styling
      const startBtn = document.getElementById('start-stress');
      if (startBtn) {
        startBtn.classList.remove('running');
        startBtn.classList.add('completed');
        startBtn.textContent = '✓ Complete';
        startBtn.style.background = 'var(--eko-success)';
      }
      
      // Update impact display to show completion
      const graphValue = document.getElementById('graph-current-value');
      if (graphValue) {
        // Keep the final percentage but add "Done" indicator
        graphValue.textContent = 'Done';
        graphValue.style.color = 'var(--eko-success)';
      }
    },

    startTest() {
      const input = document.getElementById('share-url');
      if (input) {
        console.log('%c[eko Panel] Starting test, navigating to:', 'color: #6366f1; font-weight: bold;', input.value);
        window.location.href = input.value;
      } else {
        console.error('[eko Panel] Could not find share-url input!');
      }
    },

    stopTest() {
      if (window.__stressState) {
        window.__stressState.active = false;
      }
      // Don't reload - just let the test end naturally via onTestEnded()
      // The UI will update on the next metrics interval
    },

    togglePanel() {
      console.log('[eko Panel] togglePanel called');
      const panel = document.getElementById('cpu-stress-panel');
      const body = document.getElementById('eko-stress-body');
      
      if (!panel || !body) {
        console.error('[eko Panel] togglePanel: panel or body not found');
        return;
      }
      
      const isMinimized = panel.classList.toggle('minimized');
      body.style.display = isMinimized ? 'none' : 'block';
      
      // Rotate the arrow icon
      const toggleBtn = document.getElementById('eko-panel-toggle');
      if (toggleBtn) {
        toggleBtn.style.transform = isMinimized ? 'rotate(180deg)' : 'rotate(0deg)';
      }
      console.log('[eko Panel] Panel minimized:', isMinimized);
    },

    makeDraggable() {
      console.log('[eko Panel] Setting up drag and toggle...');
      const panel = document.getElementById('cpu-stress-panel');
      
      if (!panel) {
        console.error('[eko Panel] makeDraggable: panel not found');
        return;
      }
      
      const header = panel.querySelector('.eko-stress-header');
      if (!header) {
        console.error('[eko Panel] makeDraggable: header not found');
        return;
      }
      
      const self = this;
      let isDragging = false;
      let startX, startY, startLeft, startTop;
      
      // Restore saved position from localStorage
      try {
        const savedPos = localStorage.getItem('ekoStressPanelPosition');
        if (savedPos) {
          const pos = JSON.parse(savedPos);
          panel.style.right = 'auto';
          panel.style.left = pos.left + 'px';
          panel.style.top = pos.top + 'px';
          console.log('[eko Panel] Restored position from localStorage:', pos);
        }
      } catch (e) {
        console.warn('[eko Panel] Could not restore position:', e);
      }

      // Toggle button click handler
      const toggleBtn = document.getElementById('eko-panel-toggle');
      if (toggleBtn) {
        toggleBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          e.preventDefault();
          self.togglePanel();
        }, true);
      }

      // Drag handlers
      header.addEventListener('mousedown', function(e) {
        if (toggleBtn && (e.target === toggleBtn || toggleBtn.contains(e.target))) {
          return;
        }
        
        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        
        const rect = panel.getBoundingClientRect();
        startLeft = rect.left;
        startTop = rect.top;
        
        panel.style.transition = 'none';
        header.style.cursor = 'grabbing';
        e.preventDefault();
      }, true);

      document.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        
        const newLeft = startLeft + e.clientX - startX;
        const newTop = startTop + e.clientY - startY;
        
        const maxLeft = window.innerWidth - panel.offsetWidth;
        const maxTop = window.innerHeight - 52;
        
        panel.style.right = 'auto';
        panel.style.left = Math.max(0, Math.min(newLeft, maxLeft)) + 'px';
        panel.style.top = Math.max(0, Math.min(newTop, maxTop)) + 'px';
      }, true);

      document.addEventListener('mouseup', function() {
        if (isDragging) {
          isDragging = false;
          panel.style.transition = '';
          header.style.cursor = 'grab';
          
          // Save position to localStorage
          try {
            const rect = panel.getBoundingClientRect();
            localStorage.setItem('ekoStressPanelPosition', JSON.stringify({
              left: rect.left,
              top: rect.top
            }));
            console.log('[eko Panel] Saved position to localStorage');
          } catch (e) {
            console.warn('[eko Panel] Could not save position:', e);
          }
        }
      }, true);
      
      header.style.cursor = 'grab';
      console.log('[eko Panel] Drag handlers set up');
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => EkoStress.init());
  } else {
    EkoStress.init();
  }
})();
</script>
