        <path fill-rule="evenodd" clip-rule="evenodd" d="M29.5267 12.6408C29.5267 8.57686 32.8295 5.28158 36.9026 5.28158C40.9834 5.28158 44.2862 8.57686 44.2786 12.6408C44.2786 16.7047 40.9758 20 36.9026 20C32.8295 20 29.5267 16.7047 29.5267 12.6408ZM33.9507 12.6484C33.9507 14.4597 35.2703 15.7686 36.9026 15.7686C38.535 15.7686 39.8545 14.4521 39.8545 12.6484C39.8545 10.8371 38.535 9.52055 36.9026 9.52055C35.2703 9.52055 33.9507 10.8371 33.9507 12.6484Z" fill="white"/>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M0 12.6408C0 8.57686 3.30278 5.28158 7.37595 5.28158C11.4491 5.28158 14.7519 8.57686 14.7519 12.6408C14.7519 13.1126 14.7061 13.5769 14.6222 14.0259H4.41642C4.91984 15.449 6.03348 16.172 7.41409 16.172C8.73368 16.172 9.32863 15.7839 9.79392 15.2359H14.279C13.2264 18.0213 10.5338 20 7.37595 20C3.30278 20 0 16.7047 0 12.6408ZM7.37595 9.14002C6.03348 9.14002 4.88933 9.9315 4.41641 11.2557H10.3355C9.87019 9.9315 8.71842 9.14002 7.37595 9.14002Z" fill="white"/>
      </svg>
      <span class="eko-stress-title">Stress Test</span>
    </div>
    <button id="eko-panel-toggle" class="eko-panel-toggle" title="Minimize panel">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
  
  <div id="eko-stress-body" class="eko-stress-body">
    <!-- Active Test Banner -->
    <div id="active-test-banner" class="eko-active-banner" style="display: none;">
      <div class="banner-pulse"></div>
      <div class="banner-content">
        <strong>Test Running</strong>
        <span>Blocking main thread during gallery load</span>
      </div>
    </div>

    <!-- Status Display -->
    <div class="eko-stress-status">
      <div class="eko-status-row">
        <span class="status-indicator" id="status-indicator">
          <span class="status-dot" id="status-dot"></span>
          <span id="status-text">Ready</span>
        </span>
      </div>
      <div class="eko-metrics">
        <div class="eko-metric">
          <span class="metric-value" id="elapsed-time">0.0s</span>
          <span class="metric-label">Elapsed</span>
        </div>
        <div class="eko-metric">
          <span class="metric-value" id="thread-blocked">0ms</span>
          <span class="metric-label">Blocked</span>
        </div>
        <div class="eko-metric">
          <span class="metric-value" id="total-ops">0</span>
          <span class="metric-label">Operations</span>
        </div>
      </div>
    </div>

    <!-- Real-time Stats -->
    <div class="eko-graph-section" id="graph-section">
      <div class="eko-graph-header">
        <label class="eko-label">Blocking Impact</label>
        <span class="eko-graph-value" id="graph-current-value">0%</span>
      </div>
      
      <!-- Impact meter - shows what % of time is being blocked -->
      <div class="eko-impact-meter">
        <div class="impact-bar-bg">
          <div class="impact-tick" id="impact-tick" style="left: 0%;">
            <div class="tick-line" style="display:block;width:6px;height:32px;background:#fff;border-radius:3px;border:2px solid rgba(0,0,0,0.4);box-shadow:0 0 8px rgba(0,0,0,0.5);"></div>
            <div class="tick-value" id="tick-value">0%</div>
          </div>
        </div>
        <div class="impact-labels">
          <span>0%</span>
          <span>Low Impact</span>
          <span>High Impact</span>
          <span>100%</span>
        </div>
      </div>
      
      <div class="eko-graph-stats">
        <div class="graph-stat">
          <span class="stat-label">Avg Block</span>
          <span class="stat-value" id="graph-avg">0ms</span>
        </div>
        <div class="graph-stat">
          <span class="stat-label">Est. FPS</span>
          <span class="stat-value" id="graph-fps">60fps</span>
        </div>
        <div class="graph-stat">
          <span class="stat-label">Block Rate</span>
          <span class="stat-value" id="graph-block-rate">0%</span>
        </div>
      </div>
    </div>

    <!-- URL Preview -->
    <div class="eko-url-preview">
      <label class="eko-label">Shareable URL</label>
      <div class="url-container">
        <input type="text" id="share-url" class="url-input" readonly>
        <button class="url-copy-btn" onclick="EkoStress.copyURL()" title="Copy URL">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M3 11V3C3 2.44772 3.44772 2 4 2H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    </div>

    <!-- Intensity Control -->
    <div class="eko-control">
      <label class="eko-label">Intensity</label>
      <div class="eko-btn-group">
        <button class="eko-btn" data-level="off" onclick="EkoStress.setIntensity('off')">Off</button>
        <button class="eko-btn" data-level="low" onclick="EkoStress.setIntensity('low')">Low</button>
        <button class="eko-btn" data-level="medium" onclick="EkoStress.setIntensity('medium')">Medium</button>
        <button class="eko-btn" data-level="high" onclick="EkoStress.setIntensity('high')">High</button>
        <button class="eko-btn" data-level="extreme" onclick="EkoStress.setIntensity('extreme')">Extreme</button>
      </div>
    </div>

    <!-- Duration Control -->
    <div class="eko-control">
      <label class="eko-label">Duration</label>
      <div class="eko-btn-group">
        <button class="eko-btn" data-duration="5" onclick="EkoStress.setDuration(5)">5s</button>
        <button class="eko-btn" data-duration="10" onclick="EkoStress.setDuration(10)">10s</button>
        <button class="eko-btn" data-duration="15" onclick="EkoStress.setDuration(15)">15s</button>
        <button class="eko-btn" data-duration="30" onclick="EkoStress.setDuration(30)">30s</button>
        <button class="eko-btn" data-duration="60" onclick="EkoStress.setDuration(60)">60s</button>
        <button class="eko-btn" data-duration="0" onclick="EkoStress.setDuration(0)">∞</button>
      </div>
    </div>

    <!-- Stress Type Toggles - Inline -->
    <div class="eko-control">
      <label class="eko-label">Stress Types</label>
      <div class="eko-toggles-inline">
        <label class="eko-toggle-inline checked" id="toggle-js-wrap">
          <input type="checkbox" id="toggle-js" checked onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">JS Compute</span>
          <span class="eko-tooltip-icon" data-tooltip="Heavy math operations (sqrt, sin, cos, tan) that stress the CPU and show up as scripting time in DevTools.">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><text x="7" y="10.5" text-anchor="middle" fill="currentColor" font-size="9" font-weight="600">?</text></svg>
          </span>
        </label>
        <label class="eko-toggle-inline checked" id="toggle-layout-wrap">
          <input type="checkbox" id="toggle-layout" checked onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">Layout Shift</span>
          <span class="eko-tooltip-icon" data-tooltip="Forces layout recalculations by reading and writing layout properties. Shows as purple 'Layout' bars in DevTools Performance.">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><text x="7" y="10.5" text-anchor="middle" fill="currentColor" font-size="9" font-weight="600">?</text></svg>
          </span>
