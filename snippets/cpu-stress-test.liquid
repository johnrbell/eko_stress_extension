      <button id="stop-stress" class="eko-action-btn eko-action-secondary" onclick="EkoStress.stopTest()">
        Stop
      </button>
    </div>

    <!-- Info Accordion -->
    <details class="eko-info">
      <summary>How it works</summary>
      <div class="info-content">
        <p><strong>URL-Based Configuration:</strong> All settings are stored in the URL. Share the link to run identical tests.</p>
