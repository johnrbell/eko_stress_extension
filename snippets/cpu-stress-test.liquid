          <input type="checkbox" id="toggle-memory" onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">Memory</span>
          <span class="eko-tooltip-icon" data-tooltip="Allocates large typed arrays and releases them to trigger garbage collection. Watch for GC pauses in DevTools Memory timeline.">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><text x="7" y="10.5" text-anchor="middle" fill="currentColor" font-size="9" font-weight="600">?</text></svg>
          </span>
        </label>
        <label class="eko-toggle-inline" id="toggle-dom-wrap">
          <input type="checkbox" id="toggle-dom" onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">DOM Tree</span>
          <span class="eko-tooltip-icon" data-tooltip="Creates and removes deeply nested DOM nodes to stress the render tree. Increases node count and triggers layout/paint work.">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><text x="7" y="10.5" text-anchor="middle" fill="currentColor" font-size="9" font-weight="600">?</text></svg>
          </span>
        </label>
        <label class="eko-toggle-inline" id="toggle-network-wrap">
          <input type="checkbox" id="toggle-network" onchange="EkoStress.updateToggle(this)">
          <span class="toggle-switch"></span>
          <span class="toggle-text">Event Loop</span>
          <span class="eko-tooltip-icon" data-tooltip="Fires many async fetch() calls to saturate the browser's task queue. Stresses event loop scheduling and microtask processing.">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><text x="7" y="10.5" text-anchor="middle" fill="currentColor" font-size="9" font-weight="600">?</text></svg>
          </span>
        </label>
      </div>
    </div>

