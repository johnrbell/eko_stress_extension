<script>
    window.eko = window.eko || {};
    window.eko.mediaVariantMap =
    {
        {% for media in product.media %}
          {% if media.alt contains option_prefix %}
            {% assign variants_list = '' %}
            {% assign option_values = media.alt | split: option_prefix | last | split: ',' %}
            {% for variant in product.variants %}
                {% assign variant_options = '' %}
                {% for variant_option in variant.options %}
                  {% capture variant_options %}{{variant_options}}{% unless forloop.first %},{% endunless %}{{variant_option | handleize}}{% endcapture %}
                {% endfor %}
                {% assign variant_options = variant_options | split: ',' %}
              {% for option_value in option_values %}
                {% assign option_value_handleized = option_value | handleize %}
                {% if variant_options contains option_value_handleized %}
                  {% capture variants_list %}{{variants_list}}{% unless variants_list == blank %},{% endunless %}'{{variant.id}}'{% endcapture %}
                {% endif %}
              {% endfor %}
            {% endfor %}
            {{ media.id }}: [{{ variants_list }}]{% unless forloop.last %},{% endunless %}
          {% endif %}
        {% endfor %}
    }
</script>