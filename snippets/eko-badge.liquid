<script>
  document.addEventListener('DOMContentLoaded', () => { 
    //wait for ready and say hello
    console.log('%c[eko]%c %c[v1.12.4.0] dynamic badge script running', 'background-color:#70D', 'background-color:transparent;','background-color:#AAA; color:#000');

    //place the badge and child element on the page
    const eko_badge = document.createElement('div') //create a div for the badge
    eko_badge.id = 'eko_badge' //add id
    const badge_paragraph = document.createElement('p'); //create a p for the badge text
    badge_paragraph.classList.add('badge_paragraph') //add classname
    eko_badge.appendChild(badge_paragraph) //stick p into badge div
    const eko_container = document.querySelector('.eko-smart-gallery-container') //badge container target.
    eko_container.before(eko_badge) //forces badge div into eko-gallery container 
    
    //location format is [thumbnail, slide]
    let badge_data = [
    {id: ["49896704868642"],
      slides: [
      {location: [0,0], 
        url: 'https://cdn.shopify.com/s/files/1/0833/9764/0482/files/eko_ast.webp?v=1762439576&width=300',
        text: 'Now With Kraken Plus 240 RGB',
        className: 'img_txt'
      },
      {location: [1,0], 
        url: 'https://cdn.shopify.com/s/files/1/0833/9764/0482/files/eko_ast.webp?v=1762439576&width=300',
        text: '',
        className: 'img'
      },
      {location: [2,0], 
        url: '',
        text: 'Testing Text Only!',
        className: 'txt'
      }
    ]},
    {id: ["49896705425698"],
      slides: [
      {location: [0,0], 
        url: 'https://cdn.shopify.com/s/files/1/0833/9764/0482/files/heavys_badge.png?v=1762453507&width=300',
        text: 'Now With Kraken Plus 240 RGB',
        className: 'img_txt'
      },
      {location: [0,1], 
        url: 'https://cdn.shopify.com/s/files/1/0833/9764/0482/files/heavys_badge.png?v=1762453507&width=300',
        text: '',
        className: 'img'
      },
      {location: [1,0], 
        url: '',
        text: 'Testing Text Only!',
        className: 'txt'
      }                
    ]}
    ]

    //helper function to get the current variant id served from eko player.
    const getVarId = (event) => {
      let url = new URL(event.target.location.href);
      return url.searchParams.get('variant'); 
    }

    //helper function to get the slides associated with a specific variant id.
    const getBadgeDataObject = (varId) => {
      let match = badge_data.find(badge => badge.id.includes(varId));
      return match.slides
    } 

    //helper function to get the slides associated with a specific item and module.
    const parseSlideData = (slides, a_i, a_m) => {
      return slides.find(slide => slide.location[0] === a_i && slide.location[1] === a_m);                
    }

    //helper function to build the image bg property
    const createImgBadge = (url) => {
      eko_badge.style.display = 'block'//show it if on module1, slide1
      eko_badge.style.backgroundImage = `url("${url}")`//set background
    }

    //helper function to place the text in the p tag
    const createTxtBadge = (text) => {
      eko_badge.style.display = 'block'//show it if on module1, slide1
      badge_paragraph.innerHTML = text
    }              

    //helper function to hide the badge pieces.
    const unshow = () => {
      eko_badge.style.display = "none" //hide the badge
      eko_badge.style.backgroundImage = `unset`
      badge_paragraph.innerHTML = ''        
    }

    //helper function to set the initial badge state based on the intial variant loaded.
    const setupBadge = (varId) =>{
      let match1 = badge_data.find(badge => badge.id.includes(varId));
      if (match1 != undefined){
        let match2 = match1.slides.find(slide => slide.location[0] == 0 && slide.location[1]==0)
        modDom(match2)    
      }else{
        unshow() 
      }
    }

    //helper function to change the classname of the eko_badge element
    const modClassname = (slideData) =>{
        eko_badge.className = ""
        eko_badge.className = slideData.className    
    }
    
    //helper function to determine how to build the dom based on presence of badge data
    const modDom = (slideData) =>{
      if (slideData.text){ //process just text badge
        createTxtBadge(slideData.text)
        eko_badge.style.backgroundImage = `unset`
        modClassname(slideData)
      }
      if (slideData.url){ //process just img badge
        createImgBadge(slideData.url)
        badge_paragraph.innerHTML = ''
        modClassname(slideData)
      }
      if (slideData.text && slideData.url){ //process text and img badge
        createTxtBadge(slideData.text)
        createImgBadge(slideData.url)
        modClassname(slideData)
      }    
    }

    //event listener for the change of slides
    window.addEventListener('message', (event) => { //listen for incoming messages from eko player
      if (event.origin == 'https://play.eko.com' && event.data.type == 'eko.block.event') { //check event origin & type
        let a_i = event.data.data.data.activeItemIndex //get active item
        let a_m = event.data.data.data.activeModuleIndex //get active module
      
        if (a_i != undefined && a_m != undefined){                    
          console.log(`%c[eko]%c %cthumbnail: ${a_i}, module: ${a_m}, var: ${getVarId(event)}`, 'background-color:#70D', 'background-color:transparent;','background-color:#AAA; color:#000');
          let slides = getBadgeDataObject(getVarId(event))
          let slideData = parseSlideData(slides, a_i, a_m)
          
          if (slideData){ //if you have slide data for this slide
            modDom(slideData)
          }else{ //if slideData is not found
            unshow() 
          }
        }
      }
    })   

    //initial state setup. get id and call setupBadge()
    let varId = document.querySelector('.eko-gallery').getAttribute('data-activevariant') 
    setupBadge(varId)
    
    //listen to variant change and trigger a swap accordingly. 
    window.subscribe('variant-change', (e) => {
      const variantId = e?.data?.variant?.id;
      
      // we need to pass a_i and a_m to this setup function OR change it to a function that swaps slides to the slide it was on for a variant. 

      setupBadge(variantId.toString())
    });
  })
</script>

<style>
  #eko_badge{
    z-index: 2;
    position: absolute;
    background-size: contain;
    background-repeat: no-repeat;
  }
  .badge_paragraph{
    font-size: 12pt;
  }

  #eko_badge.img_txt{
    left: 50%;
    top: 75px;
    width: 350px;
    height: 80px;
    position: absolute;
    border-radius: 10px;
    background-color: #8a00fc;
  }

  #eko_badge.img_txt .badge_paragraph{
    color: white;
    margin-top: 22px;
    margin-left: 90px;
    position: absolute;
  }

  #eko_badge.img{
    left: 5%;
    top: 75px;
    left: 20px;
    width: 180px;
    height: 180px;
    position: absolute;
    border-radius: 10px;
    border: 5px solid #8a00fc;
  }

  #eko_badge.txt{
    top:40px;
    width: 300px;
    height: 50px;
    right: -70px;
    color: white;
    position: relative;
    text-align: center;
    line-height: 12px;
    position: absolute;
    transform: rotate(45deg);
    background-color:#8a00fc;
  }
</style>